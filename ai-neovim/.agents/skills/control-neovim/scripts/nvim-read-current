#!/usr/bin/env bash
# nvim-read-current [--server <socket>]
# Print the active file, line, and column.
# Output: <absolute-path>:<line>:<col>
set -euo pipefail

SCRIPTS_DIR="$(cd "$(dirname "$0")" && pwd)"
server=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --server | -s) server="$2"; shift 2 ;;
    --) shift; break ;;
    -*) echo "nvim-read-current: unknown option: $1" >&2; exit 1 ;;
    *) echo "nvim-read-current: unexpected argument: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$server" ]]; then
  server="$("$SCRIPTS_DIR/nvim-list-servers")"
fi

nvim --server "$server" --headless \
  --remote-expr "expand('%:p') . ':' . line('.') . ':' . col('.')"
