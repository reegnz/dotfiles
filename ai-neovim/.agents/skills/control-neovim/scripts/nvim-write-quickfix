#!/usr/bin/env bash
# nvim-write-quickfix [--server <socket>] [--efm <errorformat>]
# Read entries from stdin, populate quickfix list, jump to first.
# Without --efm, Neovim's current errorformat is used.
set -euo pipefail

SCRIPTS_DIR="$(cd "$(dirname "$0")" && pwd)"
server=""
efm=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --server | -s)
      server="$2"
      shift 2
      ;;
    --efm)
      efm="$2"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "nvim-write-quickfix: unknown option: $1" >&2
      exit 1
      ;;
    *)
      echo "nvim-write-quickfix: unexpected argument: $1" >&2
      exit 1
      ;;
  esac
done

if [[ -z "$server" ]]; then
  server="$("$SCRIPTS_DIR/nvim-list-servers")"
fi

tmpfile=$(mktemp)
trap 'rm -f "$tmpfile"' EXIT
cat > "$tmpfile"

# $tmpfile and $efm are controlled values, safe to embed in the vimscript string.
# The server process cannot see client-side env vars.
if [[ -n "$efm" ]]; then
  nvim --server "$server" --headless \
    --remote-expr "execute('let s=&efm | set efm=$efm | cfile $tmpfile | cfirst | let &efm=s')"
else
  nvim --server "$server" --headless \
    --remote-expr "execute('cfile $tmpfile | cfirst')"
fi
