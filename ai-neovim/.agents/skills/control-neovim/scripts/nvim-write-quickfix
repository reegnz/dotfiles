#!/usr/bin/env bash
# nvim-write-quickfix [--server <socket>] [--efm <errorformat>]
# Read entries from stdin, populate quickfix list, jump to first.
# Without --efm, defaults to %f:%l:%c:%m (file:line:col:message).
set -euo pipefail

SCRIPTS_DIR="$(cd "$(dirname "$0")" && pwd)"
server=""
efm=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --server | -s)
      server="$2"
      shift 2
      ;;
    --efm)
      efm="$2"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "nvim-write-quickfix: unknown option: $1" >&2
      exit 1
      ;;
    *)
      echo "nvim-write-quickfix: unexpected argument: $1" >&2
      exit 1
      ;;
  esac
done

if [[ -z "$server" ]]; then
  server="$("$SCRIPTS_DIR/nvim-find-server")"
fi

tmpfile=$(mktemp)
trap 'rm -f "$tmpfile"' EXIT
cat > "$tmpfile"

if [[ -n "$efm" ]]; then
  efm_ve=$(printf '%s' "$efm" | sed "s/'/''/g")
  nvim --server "$server" --headless \
    --remote-expr "execute('let s=&efm | let &efm=''${efm_ve}'' | cfile ${tmpfile} | let &efm=s | copen | cfirst')"
else
  nvim --server "$server" --headless \
    --remote-expr "execute('cfile $tmpfile | copen | cfirst')"
fi
