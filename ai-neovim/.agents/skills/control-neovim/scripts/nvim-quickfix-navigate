#!/usr/bin/env bash
# nvim-quickfix-navigate [--server <socket>] <first|last|next|previous>
# Jump to an entry in the quickfix list.
set -euo pipefail

SCRIPTS_DIR="$(cd "$(dirname "$0")" && pwd)"
server=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --server | -s) server="$2"; shift 2 ;;
    --) shift; break ;;
    -*) echo "nvim-quickfix-navigate: unknown option: $1" >&2; exit 1 ;;
    *) break ;;
  esac
done

if [[ $# -ne 1 ]]; then
  echo "usage: nvim-quickfix-navigate [--server <socket>] <first|last|next|previous>" >&2
  exit 1
fi

case "$1" in
  first)    cmd="cfirst" ;;
  last)     cmd="clast" ;;
  next)     cmd="cnext" ;;
  previous) cmd="cprev" ;;
  *) echo "nvim-quickfix-navigate: unknown direction: $1 (must be first, last, next, or previous)" >&2; exit 1 ;;
esac

if [[ -z "$server" ]]; then
  server="$("$SCRIPTS_DIR/nvim-find-server")"
fi

nvim --server "$server" --headless \
  --remote-expr "execute('$cmd')"
