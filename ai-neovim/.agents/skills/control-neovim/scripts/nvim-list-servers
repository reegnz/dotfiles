#!/usr/bin/env bash
# nvim-list-servers
# Discover a Neovim server socket from ~/.cache/nvim/servers/.
#   - One result  → print it
#   - Multiple    → print list to stderr, exit 1 (caller must set $NVIM_ADDR)
#   - None        → exit 1 with instructions
set -euo pipefail

socks=()
for f in ~/.cache/nvim/servers/*.sock; do
  [[ -e "$f" ]] && socks+=("$f")
done

case "${#socks[@]}" in
  0)
    echo "nvim-list-servers: no Neovim servers found; run :NvimListen in a Neovim instance" >&2
    exit 1
    ;;
  1)
    echo "${socks[0]}"
    ;;
  *)
    echo "nvim-list-servers: multiple servers found, set NVIM_ADDR to one of:" >&2
    printf '  %s\n' "${socks[@]}" >&2
    exit 1
    ;;
esac
