#!/usr/bin/env bash
# nvim-read-buffers [--server <socket>]
# List open buffers with their absolute paths.
# Output: <bufnr>\t<absolute-path>  (one per line)
set -euo pipefail

SCRIPTS_DIR="$(cd "$(dirname "$0")" && pwd)"
server=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --server | -s) server="$2"; shift 2 ;;
    --) shift; break ;;
    -*) echo "nvim-read-buffers: unknown option: $1" >&2; exit 1 ;;
    *) echo "nvim-read-buffers: unexpected argument: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$server" ]]; then
  server="$("$SCRIPTS_DIR/nvim-list-servers")"
fi

nvim --server "$server" --headless \
  --remote-expr "join(map(filter(range(1, bufnr('\$')), 'buflisted(v:val)'), 'v:val . \"\t\" . fnamemodify(bufname(v:val), \":p\")'), \"\n\")"
